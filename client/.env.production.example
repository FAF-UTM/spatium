# Production build config for Cloudflare Pages.
# Copy to ".env.production" and set it to your deployed Northflank backend URL.
# Vite bakes this into the bundle at build time (it is a public URL, not a secret).
#
#   cp .env.production.example .env.production
#   # then edit the value below
VITE_API_URL=https://spatium-api--your-project.code.run
